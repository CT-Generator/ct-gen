# Conspiracy Generator v2 — environment template.
# Copy to .env (NEVER commit). On Hetzner the live values come from Compose secrets.

NODE_ENV=development

# Postgres — the local dev default points at the Compose db container.
DATABASE_URL=postgres://app:app@localhost:5432/cgen

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5
OPENAI_MODEL_FALLBACK=gpt-5-mini
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Anonymous session hash — generate with:
#   openssl rand -hex 32
SESSION_HASH_SALT=replace-with-32-bytes-of-random-hex

# Public-facing base URL — used for OG card image links, share intents, etc.
PUBLIC_BASE_URL=https://conspiracy-generator.duckdns.org
